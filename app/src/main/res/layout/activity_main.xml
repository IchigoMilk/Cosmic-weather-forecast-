<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/terminal_bg"
    android:orientation="vertical"
    android:padding="8dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingBottom="4dp">

        <TextView
            android:id="@+id/tvLocation"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:typeface="monospace"
            android:textColor="@color/terminal_cyan"
            android:textSize="11sp"
            android:text="LOC: Kobe, Japan"/>

        <TextView
            android:id="@+id/tvGpsBtn"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:typeface="monospace"
            android:textColor="@color/terminal_yellow"
            android:textSize="11sp"
            android:paddingLeft="12dp"
            android:paddingRight="4dp"
            android:text="[GPS]"/>

        <TextView
            android:id="@+id/tvCityBtn"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:typeface="monospace"
            android:textColor="@color/terminal_yellow"
            android:textSize="11sp"
            android:paddingLeft="4dp"
            android:text="[CITY]"/>
    </LinearLayout>

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/terminal_green_dim"/>

    <ScrollView
        android:id="@+id/scrollView"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:scrollbars="vertical">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tvSpaceWeather"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:typeface="monospace"
                android:textColor="@color/terminal_green"
                android:textSize="11sp"
                android:paddingTop="8dp"
                android:paddingBottom="8dp"
                android:text="Fetching space weather data..."/>

            <TextView
                android:id="@+id/tvWeather"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:typeface="monospace"
                android:textColor="@color/terminal_green"
                android:textSize="11sp"
                android:paddingTop="8dp"
                android:paddingBottom="8dp"
                android:text="Fetching weather data..."/>

            <TextView
                android:id="@+id/tvAirQuality"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:typeface="monospace"
                android:textColor="@color/terminal_green"
                android:textSize="11sp"
                android:paddingTop="8dp"
                android:paddingBottom="8dp"
                android:text="Fetching air quality data..."/>

        </LinearLayout>
    </ScrollView>

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/terminal_green_dim"/>

    <TextView
        android:id="@+id/tvStatus"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:typeface="monospace"
        android:textColor="@color/terminal_green_dim"
        android:textSize="10sp"
        android:paddingTop="4dp"
        android:text="SYS: INITIALIZING..."/>

</LinearLayout>
